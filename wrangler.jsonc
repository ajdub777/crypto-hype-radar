{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "hype-radar",
  "compatibility_date": "2026-04-14",
  "main": "worker.js",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "."
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "kv_namespaces": [
    {
      "binding": "HYPE_CACHE",
      "id": "f4b05cfaf57942a393f3b3569fdba034"
    }
  ],
  "triggers": {
    "crons": ["*/5 * * * *"]
  }
}
